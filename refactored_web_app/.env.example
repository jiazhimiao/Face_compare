FACE_COMPARE_SERVICE_NAME=face-compare-python-service
FACE_COMPARE_SERVICE_VERSION=1.0.0
FACE_COMPARE_SERVICE_ENV=prod
FACE_COMPARE_APP_HOST=0.0.0.0
FACE_COMPARE_APP_PORT=5000
FACE_COMPARE_APP_DEBUG=false
FACE_COMPARE_AUTH_TOKEN=replace-with-secure-token
FACE_COMPARE_MODEL_NAME=buffalo_l
FACE_COMPARE_MODEL_ROOT=~/.insightface
FACE_COMPARE_DEVICE_ID=-1
FACE_COMPARE_DET_THRESH=0.5
FACE_COMPARE_INPUT_WIDTH=640
FACE_COMPARE_INPUT_HEIGHT=640
FACE_COMPARE_IDENTITY_THRESHOLD=0.60
FACE_COMPARE_BLACKLIST_THRESHOLD=0.65
FACE_COMPARE_MAX_CONTENT_LENGTH=10485760
FACE_COMPARE_REQUEST_TIMEOUT_SECONDS=30
